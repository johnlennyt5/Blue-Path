# Edge Function secrets (SERVER-SIDE ONLY — never referenced by the web app).
# Local: copy to supabase/functions/.env (gitignored) and restart `supabase start`.
# Hosted: set via `supabase secrets set KEY=value` — no file involved.

# Enables real AI narratives through llm-proxy. Configure EITHER provider —
# without any key the function returns a clean 503. If both are set,
# LLM_PROVIDER picks (default: anthropic).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LLM_PROVIDER=anthropic   # or: openai

# Optional overrides (defaults shown)
# LLM_MODEL=claude-sonnet-5   # anthropic default; openai default: gpt-4o-mini
# LLM_RATE_LIMIT_PER_HOUR=30
# LLM_MAX_PAYLOAD_BYTES=100000

# invite-member: where the invite email's sign-in link lands
# INVITE_REDIRECT_URL=http://localhost:5173
