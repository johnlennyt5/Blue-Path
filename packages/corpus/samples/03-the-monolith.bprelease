          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <subsheet subsheetid="f3f3f3f3-0000-4000-9000-000000000260" type="Normal" published="False">
          <name>Refresh</name>
          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000240" name="Start" type="Start">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000239</subsheetid>
          <display x="15" y="30" />
          <inputs>
            <input type="password" name="Password" narrative="" stage="Password" />
          </inputs>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000241</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000241" name="Enter Credentials" type="Write">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000239</subsheetid>
          <display x="15" y="60" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000237" expr="[Password]" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000242</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000242" name="Click Log In" type="Navigate">
