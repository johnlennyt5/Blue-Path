    <object id="f3f3f3f3-0000-4000-9000-000000000208" name="Ledger Terminal VBO" xmlns="">
      <process name="Ledger Terminal VBO" type="object" version="1.0" bpversion="6.10.1.12345" narrative="Drives the Ledger Terminal application: login, export reads, and adjustments." byrefcollection="true">
        <appdef>
          <application name="Ledger Terminal" mode="Win32" />
          <element id="f3f3f3f3-0000-4000-9000-000000000209" name="Session Window" mode="Win32">
            <attributes>
              <attribute name="WindowText" matchtype="exact" enabled="true" value="Ledger Terminal" />
              <attribute name="ClassName" matchtype="exact" enabled="true" value="LedgerMainWnd" />
            </attributes>
          </element>
          <element id="f3f3f3f3-0000-4000-9000-000000000210" name="Grid Rows" mode="Win32">
            <attributes>
              <attribute name="ClassName" matchtype="exact" enabled="true" value="LedgerGrid" />
              <attribute name="Ordinal" matchtype="index" enabled="true" value="3" />
            </attributes>
          </element>
        </appdef>
        <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        <preconditions />
        <endpoint narrative="" />
        <subsheet subsheetid="f3f3f3f3-0000-4000-9000-000000000211" type="Normal" published="False">
          <name>Log In</name>
          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <subsheet subsheetid="f3f3f3f3-0000-4000-9000-000000000220" type="Normal" published="False">
          <name>Read Ledger Export</name>
          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <subsheet subsheetid="f3f3f3f3-0000-4000-9000-000000000226" type="Normal" published="False">
          <name>Post Adjustment</name>
          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <subsheet subsheetid="f3f3f3f3-0000-4000-9000-000000000232" type="Normal" published="False">
          <name>Refresh</name>
          <view><camerax>0</camerax><cameray>0</cameray><zoom>1</zoom></view>
        </subsheet>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000212" name="Start" type="Start">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="30" />
          <inputs>
            <input type="password" name="Password" narrative="" stage="Password" />
          </inputs>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000213</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000213" name="Enter Credentials" type="Write">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="60" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000209" expr="[Password]" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000214</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000214" name="Click Log In" type="Navigate">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="90" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000209" action="Click" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000215</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000215" name="Wait For Session" type="WaitStart">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="120" />
          <timeout>30</timeout>
          <choices>
            <choice name="Session Ready">
              <element>f3f3f3f3-0000-4000-9000-000000000209</element>
              <condition>CheckExists</condition>
              <onsuccess>f3f3f3f3-0000-4000-9000-000000000218</onsuccess>
            </choice>
          </choices>
          <ontimeout>f3f3f3f3-0000-4000-9000-000000000216</ontimeout>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000216" name="Timed Out" type="WaitEnd">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="150" />
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000217</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000217" name="Login Timeout" type="Exception">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="180" />
          <exception type="System Exception" detail="&quot;Ledger session did not appear&quot;" />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000218" name="End" type="End">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="210" />
          <outputs />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000219" name="Password" type="Data">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000211</subsheetid>
          <display x="15" y="240" />
          <datatype>password</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000221" name="Start" type="Start">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000220</subsheetid>
          <display x="15" y="270" />
          <inputs>
            <input type="text" name="Export Path" narrative="" stage="Export Path" />
          </inputs>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000222</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000222" name="Read Export" type="Code">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000220</subsheetid>
          <display x="15" y="300" />
          <inputs>
            <input type="text" name="Export Path" expr="[Export Path]" />
          </inputs>
          <outputs>
            <output type="collection" name="Rows" stage="Ledger Rows" />
          </outputs>
          <code language="vbnet"><![CDATA[
          Dim reader As New LedgerReader(Export_Path)
          Rows = reader.ReadAll()
          ]]></code>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000223</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000223" name="End" type="End">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000220</subsheetid>
          <display x="15" y="330" />
          <outputs>
            <output type="collection" name="Rows" narrative="" stage="Ledger Rows" />
          </outputs>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000224" name="Export Path" type="Data">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000220</subsheetid>
          <display x="15" y="360" />
          <datatype>text</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000225" name="Ledger Rows" type="Collection">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000220</subsheetid>
          <display x="15" y="390" />
          <collectioninfo>
            <field name="Account Number" type="text" />
            <field name="SSN" type="text" />
            <field name="Balance" type="number" />
          </collectioninfo>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000227" name="Start" type="Start">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000226</subsheetid>
          <display x="15" y="420" />
          <inputs>
            <input type="text" name="Account Number" narrative="" stage="Account Number" />
          </inputs>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000228</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000228" name="Write Account Row" type="Write">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000226</subsheetid>
          <display x="15" y="450" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000210" expr="[Account Number]" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000229</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000229" name="Commit Row" type="Navigate">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000226</subsheetid>
          <display x="15" y="480" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000210" action="Click" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000230</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000230" name="End" type="End">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000226</subsheetid>
          <display x="15" y="510" />
          <outputs />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000231" name="Account Number" type="Data">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000226</subsheetid>
          <display x="15" y="540" />
          <datatype>text</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000233" name="Start" type="Start">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000232</subsheetid>
          <display x="15" y="570" />
          <inputs />
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000234</onsuccess>
        </stage>
        <stage stageid="f3f3f3f3-0000-4000-9000-000000000234" name="Refresh Session" type="Navigate">
          <subsheetid>f3f3f3f3-0000-4000-9000-000000000232</subsheetid>
          <display x="15" y="600" />
          <steps>
            <step element="f3f3f3f3-0000-4000-9000-000000000209" action="Click" />
          </steps>
          <onsuccess>f3f3f3f3-0000-4000-9000-000000000235</onsuccess>
