    <!-- ======================================================= -->
    <!-- Object: Invoice Entry VBO                                -->
    <!-- Planted: REL-003 (Wait For Confirmation has no timeout)  -->
    <!-- ======================================================= -->
    <object id="ab8f2c31-5f77-4b2d-9c93-b6c31b2a0004" name="Invoice Entry VBO" xmlns="">
      <process name="Invoice Entry VBO" type="object" version="1.0" bpversion="6.10.1.12345" narrative="Drives the invoice web application: reads the nightly export archive and enters invoices into the web form." byrefcollection="true">
        <appdef>
          <application name="Invoice Web App" mode="HTML" />
          <element id="eeeeeeee-0000-4000-9000-00000000e001" name="Invoice Ref Field" mode="HTML">
            <attributes>
              <attribute name="tag" matchtype="exact" enabled="true" value="INPUT" />
              <attribute name="id" matchtype="exact" enabled="true" value="invoiceRef" />
            </attributes>
          </element>
          <element id="eeeeeeee-0000-4000-9000-00000000e002" name="Amount Field" mode="HTML">
            <attributes>
              <attribute name="tag" matchtype="exact" enabled="true" value="INPUT" />
              <attribute name="id" matchtype="exact" enabled="true" value="invoiceAmount" />
            </attributes>
          </element>
          <element id="eeeeeeee-0000-4000-9000-00000000e003" name="Save Button" mode="HTML">
            <attributes>
              <attribute name="tag" matchtype="exact" enabled="true" value="BUTTON" />
              <attribute name="id" matchtype="exact" enabled="true" value="saveInvoice" />
            </attributes>
          </element>
          <element id="eeeeeeee-0000-4000-9000-00000000e004" name="Confirmation Banner" mode="HTML">
            <attributes>
              <attribute name="tag" matchtype="exact" enabled="true" value="DIV" />
              <attribute name="id" matchtype="exact" enabled="true" value="confirmationBanner" />
            </attributes>
          </element>
        </appdef>
        <view>
          <camerax>0</camerax>
          <cameray>0</cameray>
          <zoom>1</zoom>
        </view>
        <preconditions />
        <endpoint narrative="" />
        <subsheet subsheetid="674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004" type="Normal" published="True">
          <name>Get Pending Invoices</name>
          <view>
            <camerax>0</camerax>
            <cameray>0</cameray>
            <zoom>1</zoom>
          </view>
        </subsheet>
        <subsheet subsheetid="674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005" type="Normal" published="True">
          <name>Enter Invoice</name>
          <view>
            <camerax>0</camerax>
            <cameray>0</cameray>
            <zoom>1</zoom>
          </view>
        </subsheet>

        <!-- Get Pending Invoices -->
        <stage stageid="dddddddd-0000-4000-9000-000000000601" name="Start" type="Start">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="15" y="-105" />
          <inputs>
            <input type="password" name="Archive Password" narrative="" stage="Archive Password" />
          </inputs>
          <onsuccess>dddddddd-0000-4000-9000-000000000602</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000602" name="Read Export File" type="Code">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="15" y="-45" />
          <inputs>
            <input type="password" name="Archive Password" expr="[Archive Password]" />
            <input type="text" name="System URL" expr="[Invoice System URL]" />
          </inputs>
          <outputs>
            <output type="collection" name="Invoices" stage="Pending Invoices" />
          </outputs>
          <code language="vbnet"><![CDATA[
' Reads the nightly export archive and returns pending invoices
Dim reader As New ExportReader(System_URL, Archive_Password)
Invoices = reader.ReadPending()
]]></code>
          <onsuccess>dddddddd-0000-4000-9000-000000000603</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000603" name="End" type="End">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="15" y="15" />
          <outputs>
            <output type="collection" name="Invoices" narrative="" stage="Pending Invoices" />
          </outputs>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000611" name="Archive Password" type="Data">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="210" y="-105" />
          <datatype>password</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000612" name="Invoice System URL" type="Data">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="210" y="-45" />
          <datatype>text</datatype>
          <initialvalue />
          <exposure>Environment</exposure>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000613" name="Pending Invoices" type="Collection">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1004</subsheetid>
          <display x="210" y="15" />
          <collectioninfo>
            <field name="Invoice Ref" type="text" />
            <field name="Amount" type="number" />
            <field name="Due Date" type="date" />
          </collectioninfo>
        </stage>

        <!-- Enter Invoice -->
        <stage stageid="dddddddd-0000-4000-9000-000000000701" name="Start" type="Start">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="15" y="-150" />
          <inputs>
            <input type="text" name="Invoice Ref" narrative="" stage="Invoice Ref" />
            <input type="number" name="Amount" narrative="" stage="Amount" />
          </inputs>
          <onsuccess>dddddddd-0000-4000-9000-000000000702</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000702" name="Write Invoice Fields" type="Write">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="15" y="-90" />
          <steps>
            <step element="eeeeeeee-0000-4000-9000-00000000e001" expr="[Invoice Ref]" />
            <step element="eeeeeeee-0000-4000-9000-00000000e002" expr="[Amount]" />
          </steps>
          <onsuccess>dddddddd-0000-4000-9000-000000000703</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000703" name="Click Save" type="Navigate">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="15" y="-30" />
          <steps>
            <step element="eeeeeeee-0000-4000-9000-00000000e003" action="Click" />
          </steps>
          <onsuccess>dddddddd-0000-4000-9000-000000000704</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000704" name="Wait For Confirmation" type="WaitStart">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="15" y="30" />
          <timeout />
          <choices>
            <choice name="Confirmation Shown">
              <element>eeeeeeee-0000-4000-9000-00000000e004</element>
              <condition>CheckExists</condition>
              <onsuccess>dddddddd-0000-4000-9000-000000000707</onsuccess>
            </choice>
          </choices>
          <ontimeout>dddddddd-0000-4000-9000-000000000705</ontimeout>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000705" name="Timed Out" type="WaitEnd">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="150" y="30" />
          <onsuccess>dddddddd-0000-4000-9000-000000000706</onsuccess>
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000706" name="Save Not Confirmed" type="Exception">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="150" y="90" />
          <exception type="System Exception" detail="&quot;Invoice save was not confirmed by the application&quot;" />
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000707" name="End" type="End">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="15" y="90" />
          <outputs />
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000711" name="Invoice Ref" type="Data">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="210" y="-150" />
          <datatype>text</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
        <stage stageid="dddddddd-0000-4000-9000-000000000712" name="Amount" type="Data">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1005</subsheetid>
          <display x="210" y="-90" />
          <datatype>number</datatype>
          <initialvalue />
          <alwaysinit />
        </stage>
      </process>
    </object>

    <!-- ======================================================= -->
    <!-- Environment                                              -->
    <!-- ======================================================= -->
    <work-queue id="f1f1f1f1-0000-4000-9000-000000000001" name="Invoices Queue" xmlns="">
      <keyfield>Invoice Ref</keyfield>
      <maxattempts>3</maxattempts>
      <encrypted>false</encrypted>
    </work-queue>
    <environment-variable name="Invoice System URL" xmlns="">
      <datatype>text</datatype>
      <value>https://invoices.corp.example</value>
      <description>Base URL of the invoice web application</description>
    </environment-variable>
  </bpr:contents>
</bpr:release>
