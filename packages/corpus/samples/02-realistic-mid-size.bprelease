          <collectioninfo>
            <field name="Invoice Ref" type="text" />
            <field name="Amount" type="number" />
            <field name="Due Date" type="date" />
          </collectioninfo>
        </stage>

        <!-- Process Item -->
        <stage stageid="cccccccc-0000-4000-9000-000000000501" name="Start" type="Start">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1003</subsheetid>
          <display x="15" y="-120" />
          <inputs>
            <input type="text" name="Item ID" narrative="" stage="Item ID" />
            <input type="collection" name="Item Data" narrative="" stage="Item Data" />
          </inputs>
          <onsuccess>cccccccc-0000-4000-9000-000000000502</onsuccess>
        </stage>
        <stage stageid="cccccccc-0000-4000-9000-000000000502" name="Enter Invoice" type="Action">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1003</subsheetid>
          <display x="15" y="-60" />
          <resource object="Invoice Entry VBO" action="Enter Invoice" />
