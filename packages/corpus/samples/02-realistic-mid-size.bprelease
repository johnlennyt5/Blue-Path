            <zoom>1</zoom>
          </view>
        </subsheet>

        <!-- Main Page -->
        <stage stageid="cccccccc-0000-4000-9000-000000000401" name="Start" type="Start">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1002</subsheetid>
