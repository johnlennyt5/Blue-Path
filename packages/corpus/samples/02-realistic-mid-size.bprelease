      <process name="Invoice Dispatcher" version="1.0" bpversion="6.10.1.12345" narrative="Nightly dispatcher: pulls pending invoices from the export archive via the Invoice Entry VBO and loads them into the Invoices Queue for the performer." byrefcollection="true">
