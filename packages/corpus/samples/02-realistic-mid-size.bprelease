    <process id="ab8f2c31-5f77-4b2d-9c93-b6c31b2a0003" name="Invoice Performer" xmlns="">
      <process name="Invoice Performer" version="1.0" bpversion="6.10.1.12345" narrative="Works the Invoices Queue: takes the next item, enters it into the invoice web application via the Invoice Entry VBO, and marks the item completed. Failures are marked as exceptions on the queue item and the performer moves on." byrefcollection="true">
        <view>
          <camerax>0</camerax>
          <cameray>0</cameray>
          <zoom>1</zoom>
        </view>
        <preconditions />
        <endpoint narrative="Queue drained; all items completed or exceptioned." />
        <subsheet subsheetid="674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1002" type="MainPage" published="True">
          <name>Main Page</name>
          <view>
