        <stage stageid="bbbbbbbb-0000-4000-9000-000000000302" name="Get Pending Invoices" type="Action">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="15" y="-105" />
          <resource object="Invoice Entry VBO" action="Get Pending Invoices" />
          <inputs>
            <input type="password" name="Archive Password" expr="&quot;ArchiveP@ss2024!&quot;" />
          </inputs>
          <outputs>
            <output type="collection" name="Invoices" stage="New Invoices" />
