          <onsuccess>bbbbbbbb-0000-4000-9000-000000000303</onsuccess>
        </stage>
        <stage stageid="bbbbbbbb-0000-4000-9000-000000000303" name="For Each Invoice" type="LoopStart">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="15" y="-45" />
          <groupid>abababab-0000-4000-9000-000000000001</groupid>
          <loopdata>New Invoices</loopdata>
          <onsuccess>bbbbbbbb-0000-4000-9000-000000000304</onsuccess>
        </stage>
        <stage stageid="bbbbbbbb-0000-4000-9000-000000000304" name="Add To Queue" type="Action">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="15" y="15" />
          <resource object="Work Queues" action="Add To Queue" />
          <inputs>
            <input type="text" name="Queue Name" expr="&quot;Invoices Queue&quot;" />
            <input type="collection" name="Data" expr="[New Invoices]" />
          </inputs>
          <outputs />
          <onsuccess>bbbbbbbb-0000-4000-9000-000000000305</onsuccess>
        </stage>
        <stage stageid="bbbbbbbb-0000-4000-9000-000000000305" name="End Loop" type="LoopEnd">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="15" y="75" />
          <groupid>abababab-0000-4000-9000-000000000001</groupid>
          <onsuccess>bbbbbbbb-0000-4000-9000-000000000308</onsuccess>
        </stage>
        <stage stageid="bbbbbbbb-0000-4000-9000-000000000306" name="Recover" type="Recover">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="165" y="-45" />
          <onsuccess>bbbbbbbb-0000-4000-9000-000000000307</onsuccess>
        </stage>
        <stage stageid="bbbbbbbb-0000-4000-9000-000000000307" name="Resume" type="Resume">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1001</subsheetid>
          <display x="165" y="15" />
          <onsuccess>bbbbbbbb-0000-4000-9000-000000000308</onsuccess>
