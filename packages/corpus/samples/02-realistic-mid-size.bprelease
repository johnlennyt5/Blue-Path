            <input type="text" name="Invoice Ref" expr="[Item Data.Invoice Ref]" />
            <input type="number" name="Amount" expr="[Item Data.Amount]" />
          </inputs>
          <outputs />
          <onsuccess>cccccccc-0000-4000-9000-000000000506</onsuccess>
        </stage>
        <stage stageid="cccccccc-0000-4000-9000-000000000503" name="Recover" type="Recover">
