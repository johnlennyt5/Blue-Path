        </stage>
        <stage stageid="cccccccc-0000-4000-9000-000000000505" name="Mark Exception" type="Action">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1003</subsheetid>
          <display x="165" y="60" />
          <resource object="Work Queues" action="Mark Exception" />
          <inputs>
            <input type="text" name="Queue Name" expr="&quot;Invoices Queue&quot;" />
