        </stage>
        <stage stageid="cccccccc-0000-4000-9000-000000000405" name="Mark Completed" type="Action">
          <subsheetid>674a8b1e-71c2-4b1a-9e2d-3f5a6c7d1002</subsheetid>
          <display x="15" y="60" />
