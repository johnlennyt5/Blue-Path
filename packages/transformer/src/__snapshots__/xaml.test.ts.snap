// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`emitWorkflowXaml > emits the composite workflow exactly (snapshot) 1`] = `
"<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="MainPage" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:s="clr-namespace:System;assembly=mscorlib" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib" xmlns:sd="clr-namespace:System.Data;assembly=System.Data" xmlns:ui="http://schemas.uipath.com/workflow/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="in_RunDate" Type="InArgument(s:DateTime)" />
    <x:Property Name="out_TotalMetrics" Type="OutArgument(x:Double)" />
    <x:Property Name="io_Config" Type="InOutArgument(x:Object)" />
  </x:Members>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>System.Data</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Data</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Main Page">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Default="[&quot;&quot;]" Name="Total" />
      <Variable x:TypeArguments="x:Boolean" Name="Confirmed" />
      <Variable x:TypeArguments="sd:DataTable" Name="Invoices" />
    </Sequence.Variables>
    <ui:Comment Text="Generated by PrismShift from Blue Prism page &quot;Main Page&quot;" />
    <TryCatch DisplayName="Transaction Guard">
      <TryCatch.Try>
        <ui:ForEachRow DataTable="[Invoices]" DisplayName="For Each Invoice">
          <ui:ForEachRow.Body>
            <ActivityAction x:TypeArguments="sd:DataRow">
              <ActivityAction.Argument>
                <DelegateInArgument x:TypeArguments="sd:DataRow" Name="CurrentRow" />
              </ActivityAction.Argument>
              <Sequence DisplayName="Process One Row">
                <Assign DisplayName="Compute Total">
                  <Assign.To>
                    <OutArgument x:TypeArguments="x:String">[Total]</OutArgument>
                  </Assign.To>
                  <Assign.Value>
                    <InArgument x:TypeArguments="x:String">[CurrentRow(&quot;Net&quot;).ToString + CurrentRow(&quot;Tax&quot;).ToString]</InArgument>
                  </Assign.Value>
                </Assign>
                <ui:InvokeWorkflowFile UnSafe="False" WorkflowFileName="Pages\\EnterInvoice.xaml" DisplayName="Enter Invoice">
                  <ui:InvokeWorkflowFile.Arguments>
                    <InArgument x:TypeArguments="x:String" x:Key="in_InvoiceRef">[Total]</InArgument>
                    <OutArgument x:TypeArguments="x:Boolean" x:Key="out_Confirmed">[Confirmed]</OutArgument>
                  </ui:InvokeWorkflowFile.Arguments>
                </ui:InvokeWorkflowFile>
              </Sequence>
            </ActivityAction>
          </ui:ForEachRow.Body>
        </ui:ForEachRow>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="ui:BusinessRuleException">
          <ActivityAction x:TypeArguments="ui:BusinessRuleException">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="ui:BusinessRuleException" Name="exception" />
            </ActivityAction.Argument>
            <WriteLine DisplayName="Write Line" Text="[&quot;Business rule: &quot; &amp; exception.Message]" />
          </ActivityAction>
        </Catch>
        <Catch x:TypeArguments="s:Exception">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
            </ActivityAction.Argument>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
      <TryCatch.Finally>
        <WriteLine DisplayName="Log Done" Text="[&quot;finished&quot;]" />
      </TryCatch.Finally>
    </TryCatch>
    <If Condition="[Confirmed AndAlso Total &lt;&gt; &quot;&quot;]" DisplayName="Confirmed?">
      <If.Then>
        <Assign DisplayName="Assign out_TotalMetrics">
          <Assign.To>
            <OutArgument x:TypeArguments="x:Double">[out_TotalMetrics]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:Double">[CDbl(Total)]</InArgument>
          </Assign.Value>
        </Assign>
      </If.Then>
      <If.Else>
        <WriteLine DisplayName="Write Line" Text="[&quot;not confirmed&quot;]" />
      </If.Else>
    </If>
  </Sequence>
</Activity>
"
`;
